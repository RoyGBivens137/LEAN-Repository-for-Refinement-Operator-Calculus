  degree_le := by simp [MvPolynomial.totalDegree_C]
  density_pos := fun _ => by simp [evalAtEucl, MvPolynomial.eval_C, hc]

/-- The degree of a polynomial Jacobian (the bound d, not the actual totalDegree). -/
